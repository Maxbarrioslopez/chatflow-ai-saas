# ============================================
# ChatFlow AI SaaS Platform — Environment
# ============================================
# Copy this file to .env and fill in values.
#   cp .env.example .env
# ============================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chatflow"

# --- Auth ---
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# --- Encryption (sensitive config data) ---
ENCRYPTION_KEY="change-this-to-another-random-string"

# --- AI Providers ---
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."      # Optional
OPENROUTER_API_KEY="sk-or-..."     # Optional
AI_PROVIDER="openai"                # openai | anthropic | openrouter
EMBEDDING_MODEL="text-embedding-3-small"
CHAT_MODEL="gpt-4o-mini"

# --- Redis (for BullMQ queues) ---
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://localhost:6379"  # Optional — full connection string

# --- Server ---
BACKEND_PORT="4000"
NODE_ENV="development"
LOG_LEVEL="info"
CORS_ORIGIN="http://localhost:3000"

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# --- Storage ---
UPLOAD_DIR="./uploads"

# --- Document Processing ---
MAX_UPLOAD_SIZE_MB="10"            # Maximum file upload size
DOCUMENT_CHUNK_SIZE="1000"         # Characters per chunk (LangChain splitter)
DOCUMENT_CHUNK_OVERLAP="150"       # Overlap between chunks

# --- Billing (Stripe — optional) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Email (Resend — optional) ---
RESEND_API_KEY="re_..."
